# OpenAI
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini-2024-07-18

# Admin credentials (required for /downloadit login)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Static download token for CSV endpoints (optional, for API/script access)
# If not set, only session-based auth (login) works
DOWNLOAD_TOKEN=

# CSV logging (optional)
CSV_LOG_DIR=
CSV_LOG_FILE=
CSV_LOCK_RETRIES=60
CSV_LOCK_STALE_MS=30000
